# Optional overrides for the systemd units.
# Copy to /opt/eb28.co/ops/systemd/fundmanager.env and adjust values for the VPS.

# Real provider plugin. It must expose build_provider(config) and load secrets from the environment.
# FUNDMANAGER_PROVIDER_MODULE=ops.providers.simmer_provider
# FUNDMANAGER_PROVIDER_CLASS=SimmerFundProvider
# SIMMER_API_KEY=sk_live_...

# Optional dry-run scenario for validation only.
# FUNDMANAGER_DRY_RUN_SCENARIO=/opt/eb28.co/ops/scenarios/dry-run.json

# Optional local state inputs used by the Simmer adapter for lane/report enrichment.
# FUNDMANAGER_COMMITTEE_STATE_PATH=/var/lib/fundmanager/committee-state.json
# FUNDMANAGER_PROVIDER_CACHE_PATH=/var/lib/fundmanager/fundmanager-provider-cache.json

# Optional venue credentials surfaced in provider preflight/reporting.
# KALSHI_API_KEY_ID=...
# KALSHI_PRIVATE_KEY_PATH=/secure/path/to/kalshi-key.pem
# SOLANA_PRIVATE_KEY=...

# Public JSON destination consumed by the eb28.co /api/fundmanager-data route.
# FUNDMANAGER_PUBLIC_STATE_PATH=/var/lib/fundmanager/public/fundmanager-public.json

# Optional restart hook for the watchdog when running with suitable privileges.
# FUNDMANAGER_WATCHDOG_RESTART_CMD=systemctl restart fundmanager-orchestrator.service
