# Rewrite /api/fundmanager-data to the static JSON file
RewriteEngine On
RewriteRule ^api/fundmanager-data$ /data/fundmanager-data.json [L,NC]

# Set correct Content-Type for files without extensions in api/ directory
<FilesMatch "^fundmanager-data$">
    ForceType application/json
</FilesMatch>

# Handle SPA routing - serve index.html for non-file requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/data/
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteRule ^(.*)$ /index.html [L]
